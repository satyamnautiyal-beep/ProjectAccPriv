# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=health_enroll

# ── AI Refinery ───────────────────────────────────────────────────────────────
# Required. Get your key from https://sdk.airefinery.accenture.com
AI_REFINERY_KEY=your-ai-refinery-key

# ── Open Enrollment Period ────────────────────────────────────────────────────
# Controls whether member changes are treated as SEP or OEP.
# Set to your actual enrollment window. Leave blank to disable OEP gating.
OEP_START_DATE=2025-11-01
OEP_END_DATE=2025-12-15

# ── Optional overrides ────────────────────────────────────────────────────────
# Default enrollment source when not specified in EDI envelope.
# Values: Employer | Exchange | CMS | FFE | SBE
DEFAULT_ENROLLMENT_SOURCE=Employer

# MongoDB collection name (default: members)
MONGO_COLLECTION=members
