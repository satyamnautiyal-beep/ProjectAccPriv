# ─── BigQuery Configuration (Primary Data Store) ───────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=health_enroll
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# ─── GCP Storage (SEP Evidence Documents) ───────────────────────────────────
GCP_DOCS_BUCKET=your-enrollment-docs-bucket

# ─── AI Refinery ────────────────────────────────────────────────────────────
AI_REFINERY_KEY=your-ai-refinery-key
# Fallback key names also accepted: AI_REFINERY_API_KEY, API_KEY
AIREFINERY_UUID=enrollment_dev_local

# ─── Open Enrollment Period ──────────────────────────────────────────────────
# Controls whether member changes are treated as OEP or SEP
OEP_START_DATE=2025-11-01
OEP_END_DATE=2025-12-15
OEP_TIMEZONE=UTC

# ─── Enrollment Source Default ───────────────────────────────────────────────
DEFAULT_ENROLLMENT_SOURCE=Employer

# ─── Frontend ────────────────────────────────────────────────────────────────
# Used by release-staging page to connect directly to backend for SSE streaming
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Comma-separated list of origins allowed to make credentialed requests to the API.
# Must be explicit (no wildcard) because allow_credentials=True is required for cookies.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Legacy (not used — kept for reference) ──────────────────────────────────
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=edi_data
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB_NAME=health_enroll
