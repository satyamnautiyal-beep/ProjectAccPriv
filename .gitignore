# --- Backend & Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.db
*.sqlite3

# --- Data & Workdirs ---
# Exclude all generated or ingested data
data/
parsed_data/
# Keep directory structures but not content if needed
!data/.gitkeep

# --- Synthetic Data ---
# Exclude unzipped synthetic folders/files
synthetic_data/*/
synthetic_data/edi_data
# Ensure zip samples ARE tracked
!synthetic_data/*.zip

# --- Frontend & React ---
node_modules/
.next/
out/
build/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Logs & Debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
*.pem

# --- IDE & OS ---
.vscode/
.idea/
.DS_Store
*.swp
*.bak
Thumbs.db

# --- Miscellaneous ---
.vercel/
*.tsbuildinfo
next-env.d.ts
